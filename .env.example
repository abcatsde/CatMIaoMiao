# OKX API
OKX_BASE_URL=https://www.okx.com
OKX_API_KEY=your_key
OKX_API_SECRET=your_secret
OKX_API_PASSPHRASE=your_passphrase
OKX_INST_TYPES=SPOT,SWAP
OKX_INST_LIMIT=50

# LLM
LLM_PROVIDER=siliconflow
LLM_MODEL=deepseek-ai/DeepSeek-V3.2
LLM_API_KEY=your_llm_key
LLM_BASE_URL=https://api.siliconflow.cn/v1

# Trading
TRADING_SYMBOLS=
MAX_RISK_PCT=0.01
MAX_POSITION_PCT=0.2
PAPER_TRADING=true
TRAILING_STOP_PCT=0.02
TAKE_PROFIT_PCT=0.04
STATE_STORE_PATH=data/position_state.json
MIN_PROFIT_TO_TRAIL_PCT=0.01
STOP_BY_LLM=false
USE_WEBSOCKET=true
OKX_WS_PUBLIC=wss://ws.okx.com:8443/ws/v5/public
OKX_WS_PRIVATE=wss://ws.okx.com:8443/ws/v5/private
VOL_WINDOW=20
VOL_THRESHOLD=0.05
USE_BBO=true
MAX_SPREAD_PCT=0.002
ANALYSIS_LOG_PATH=data/analysis.log
KLINE_TIMEFRAMES=1m,5m,15m,1h,4h
KLINE_LIMIT=50
FAIL_ON_LLM_ERROR=true
LLM_RETRIES=2
LLM_RETRY_BACKOFF=1.5
LLM_TIMEOUT_SEC=60
MEMORY_PATH=data/llm_memory.txt
ACTION_GUARD_ENABLED=true
ACTION_GUARD_PATH=data/action_state.json
ACTION_COOLDOWN_SEC=120
ACTION_OVERRIDE_CONFIDENCE=0.8
